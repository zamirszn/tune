{
  "name": "Flutter Codespace",

  "image": "ghcr.io/cirruslabs/flutter:stable",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter"
      }
    }
  },

  "forwardPorts": [8080],

  "postCreateCommand": "flutter pub get",

  "remoteEnv": {
    "FLUTTER_WEB_AUTO_DETECT": "true"
  }
}
